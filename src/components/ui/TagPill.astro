---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---
{href ? (
  <a
    href={href}
    class="inline-block px-2.5 py-0.5 rounded text-xs font-medium bg-border text-muted hover:text-ink transition-colors"
  >
    {tag}
  </a>
) : (
  <span class="inline-block px-2.5 py-0.5 rounded text-xs font-medium bg-border text-muted">
    {tag}
  </span>
)}
