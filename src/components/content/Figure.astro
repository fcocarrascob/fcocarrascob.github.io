---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
}

const { src, alt, caption, width } = Astro.props;
---
<figure class="my-8">
  <img
    src={src}
    alt={alt}
    width={width}
    class="mx-auto rounded border border-border max-w-full"
  />
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-muted">
      {caption}
    </figcaption>
  )}
</figure>
