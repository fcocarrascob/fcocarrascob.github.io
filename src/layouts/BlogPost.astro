---
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/ui/TagPill.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import type { SeriesNav } from '../lib/posts';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags: string[];
    norm?: string;
    section?: string;
  };
  breadcrumb?: { href: string; label: string };
  seriesNav?: SeriesNav;
}

const { frontmatter, breadcrumb, seriesNav } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <Header />
  <main class="flex-1 w-full max-w-3xl mx-auto px-4 py-12">
    <article>
      <header class="mb-10 pb-8 border-b border-border">
        {breadcrumb && (
          <a
            href={breadcrumb.href}
            class="text-sm text-muted hover:text-ink transition-colors inline-block mb-5"
          >
            &larr; {breadcrumb.label}
          </a>
        )}
        {seriesNav ? (
          <p class="text-sm font-medium text-muted uppercase tracking-wider mb-3">
            Serie · {seriesNav.name}
            <span class="text-accent"> · Parte {seriesNav.part} de {seriesNav.total}</span>
          </p>
        ) : frontmatter.section && (
          <p class="text-sm font-medium text-muted uppercase tracking-wider mb-3">
            {frontmatter.section}
          </p>
        )}
        <h1 class="text-3xl font-semibold text-ink leading-tight mb-4">
          {frontmatter.title}
        </h1>
        <p class="text-muted mb-5">{frontmatter.description}</p>
        <div class="flex items-center gap-4 text-sm text-muted">
          <time datetime={frontmatter.pubDate.toISOString()}>
            {dateFormatter.format(frontmatter.pubDate)}
          </time>
          {frontmatter.norm && (
            <span class="text-accent font-medium">{frontmatter.norm}</span>
          )}
          {frontmatter.updatedDate && (
            <span>
              Actualizado: {dateFormatter.format(frontmatter.updatedDate)}
            </span>
          )}
        </div>
        {frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {frontmatter.tags.map((tag) => <TagPill tag={tag} />)}
          </div>
        )}
      </header>

      <div class="prose prose-slate max-w-none">
        <slot />
      </div>

      {seriesNav && (seriesNav.prev || seriesNav.next) && (
        <nav class="mt-14 pt-8 border-t border-border grid grid-cols-2 gap-6 text-sm">
          <div>
            {seriesNav.prev && (
              <a href={`/blog/${seriesNav.prev.id}`} class="group block">
                <span class="block text-muted mb-1">&lsaquo; Parte {seriesNav.prev.part}</span>
                <span class="block text-ink group-hover:text-accent transition-colors font-medium">
                  {seriesNav.prev.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {seriesNav.next && (
              <a href={`/blog/${seriesNav.next.id}`} class="group block">
                <span class="block text-muted mb-1">Parte {seriesNav.next.part} &rsaquo;</span>
                <span class="block text-ink group-hover:text-accent transition-colors font-medium">
                  {seriesNav.next.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>
