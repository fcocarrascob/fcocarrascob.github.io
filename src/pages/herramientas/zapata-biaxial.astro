---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/ui/Header.astro';
import Footer from '../../components/ui/Footer.astro';
import ZapataBiaxialTool from '../../components/zapata/ZapataBiaxialTool.tsx';

const title = 'Zapata aislada biaxial';
const description =
  'Predice en el navegador el mapa de presión de contacto, la fracción en contacto y la presión máxima de una zapata aislada bajo momento biaxial, con un modelo sustituto (surrogate) entrenado sobre 3000 análisis no lineales en SAP2000.';
---
<BaseLayout title={title} description={description}>
  <Header />
  <main class="flex-1 w-full max-w-4xl mx-auto px-4 py-8">
    <header class="mb-5">
      <h1 class="text-2xl font-semibold text-ink">Zapata aislada biaxial</h1>
      <p class="mt-2 text-sm text-muted leading-relaxed">
        Ingresa la geometría, el suelo y las cargas: la herramienta calcula la rigidez relativa
        y la excentricidad, y predice el <strong>mapa de presión de contacto</strong>, el
        porcentaje de la base en compresión y la presión máxima. El motor es un
        <em>surrogate</em> de campo (POD + gradient boosting) entrenado sobre 3000 análisis no
        lineales en SAP2000 —resuelve en milisegundos el despegue biaxial, que no tiene fórmula
        cerrada. Ver la <a href="/blog/surrogate-biaxial-despegue"
        class="text-accent hover:underline">serie de fundaciones</a> para el detalle.
      </p>
    </header>

    <ZapataBiaxialTool client:only="react" />

    <details class="mt-6 text-xs text-muted">
      <summary class="cursor-pointer font-medium text-ink">Supuestos y notas del modelo</summary>
      <ul class="mt-2 space-y-1.5 list-disc pl-5 leading-relaxed">
        <li>
          <strong>Sección del pedestal: 50 × 50 cm (fija).</strong> Es la que usaron todos los
          modelos del dataset, por eso solo se ingresa su altura. Su peso es
          (50×50)·H<sub>ped</sub>·γ<sub>hormigón</sub> — un aporte pequeño a la carga vertical.
        </li>
        <li>
          <strong>Material: hormigón G25.</strong> Fija el módulo elástico E que entra en la
          rigidez relativa K<sub>r</sub> = E·T³ / (k<sub>s</sub>·B⁴).
        </li>
        <li>
          <strong>Pesos unitarios:</strong> hormigón 2400 kgf/m³, suelo de relleno 1800 kgf/m³.
        </li>
        <li>
          <strong>Carga vertical N:</strong> es la total en la base = columna + peso propio
          (zapata + pedestal) + relleno. El relleno se apoya sobre el vuelo (área B·L menos la
          huella del pedestal) y empuja hacia abajo incluso donde la base despega; por eso
          <strong>estabiliza</strong> (baja la excentricidad efectiva e = M/N).
        </li>
        <li>
          <strong>Convención de momentos:</strong> M<sub>y</sub> genera excentricidad sobre B
          (e<sub>x</sub>); M<sub>x</sub>, sobre L (e<sub>y</sub>). Sin corte horizontal.
        </li>
        <li>
          <strong>Suelo:</strong> resortes de Winkler de solo compresión —modelan el despegue,
          no la falla por capacidad de soporte ni la no linealidad del suelo.
        </li>
      </ul>
    </details>

    <p class="mt-4 text-xs text-muted">
      Herramienta de <strong>prediseño</strong>, no de proyecto definitivo. Válida dentro de la
      envolvente de entrenamiento (hormigón G25, K_r ≈ 0,01–1000, L/B ≈ 1–2,5, excentricidad
      hasta el borde muestreado). El proyecto definitivo se verifica con el análisis.
    </p>
  </main>
  <Footer />
</BaseLayout>
