---
import PageLayout from '../../layouts/PageLayout.astro';

const tools = [
  {
    href: '/herramientas/placa-base',
    title: 'Placa base de columna',
    description:
      'Verifica placas base con carga axial (compresión o tracción), momento biaxial y corte: distribución de presiones, aplastamiento, espesor de placa, pernos y anclaje al hormigón según AISC 360, Design Guide 1 y ACI 318 Cap. 17 (LRFD).',
  },
  {
    href: '/herramientas/zapata-biaxial',
    title: 'Zapata aislada biaxial',
    description:
      'Predice el mapa de presión, el contacto y la presión máxima de una zapata bajo momento biaxial, con un surrogate entrenado sobre análisis no lineales en SAP2000. Incluye barrido de combinaciones desde Joint Reactions.',
  },
  {
    href: '/herramientas/estimador-t1',
    title: 'Estimador de T₁',
    description:
      'Período fundamental, forma modal y masa participante de un pórtico plano en milisegundos, interpolando las tablas exactas de 840 análisis modales en SAP2000 — con irregularidad vertical y comparación contra Ct·H^x.',
  },
  {
    href: '/herramientas/canvas',
    title: 'Canvas matemático',
    description:
      'Lienzo de nodos conectados para cálculos reactivos con unidades. Arma checks de ACI/Eurocódigo visualmente.',
  },
  {
    href: '/herramientas/sap-scripts',
    title: 'Constructor de Scripts SAP2000',
    description:
      'Generá scripts Python listos para ejecutar contra SAP2000 a partir de un formulario: modelo base con espectros NCh2369, materiales y combinaciones LRFD/ASD/NCh.',
  },
  {
    href: '/herramientas/mcp-sap2000',
    title: 'MCP SAP2000',
    description:
      'Servidor MCP para conectar agentes de IA con SAP2000. Documentación y guía de uso del repositorio.',
  },
];
---
<PageLayout title="Herramientas" description="Utilidades interactivas de cálculo estructural">
  <div class="prose prose-slate max-w-none">
    <h1>Herramientas</h1>
    <p>Utilidades interactivas para apoyar el cálculo estructural.</p>
  </div>
  <ul class="mt-6 grid gap-4 not-prose">
    {tools.map(({ href, title, description }) => (
      <li>
        <a
          href={href}
          class="block rounded-lg border border-border bg-surface p-4 transition-colors hover:border-accent"
        >
          <h2 class="font-semibold text-ink">{title}</h2>
          <p class="mt-1 text-sm text-muted">{description}</p>
        </a>
      </li>
    ))}
  </ul>
</PageLayout>
