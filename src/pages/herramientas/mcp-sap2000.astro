---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout title="MCP SAP2000" description="Servidor MCP para conectar agentes de IA con SAP2000">
  <div class="mb-10">
    <a href="/herramientas" class="text-sm text-muted hover:text-ink transition-colors">
      &larr; Herramientas
    </a>
    <div class="mt-4">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-2">Herramientas</p>
      <h1 class="text-2xl font-semibold text-ink mb-3">MCP SAP2000</h1>
      <p class="text-muted leading-relaxed">
        Servidor MCP para conectar agentes de IA con SAP2000. Documentación y guía de uso del repositorio.
      </p>
    </div>
  </div>

  <div class="prose prose-slate max-w-none">
    <p>Contenido en construcción.</p>
  </div>
</PageLayout>
