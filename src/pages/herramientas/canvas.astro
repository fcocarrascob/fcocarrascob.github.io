---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/ui/Header.astro';
import Footer from '../../components/ui/Footer.astro';
import MathCanvas from '../../components/canvas/MathCanvas.tsx';

const title = 'Canvas matemático';
const description =
  'Hoja de cálculo estilo SMath: haz clic en cualquier parte y escribe expresiones con unidades (math.js), renderizadas con KaTeX. Útil para checks de ACI/Eurocódigo.';
---
<BaseLayout title={title} description={description}>
  <Header />
  <main class="flex-1 w-full max-w-6xl mx-auto px-4 py-8">
    <header class="mb-4">
      <h1 class="text-2xl font-semibold text-ink">Canvas matemático</h1>
      <p class="mt-1 text-sm text-muted">
        Haz clic en la hoja y escribe una expresión: <code>nombre := valor</code> define una
        variable, un <code>=</code> final muestra el resultado, y <code>= unidad</code> lo
        convierte verificando la coherencia dimensional. Las variables se comparten entre
        regiones en orden de lectura (arriba→abajo), como en SMath Studio.
      </p>
    </header>
    <div class="h-[70vh] w-full overflow-hidden rounded-lg border border-border bg-white">
      <MathCanvas client:only="react" />
    </div>
    <p class="mt-3 text-xs text-muted">
      Ejemplo: <code>fy := 420 MPa</code>, <code>As := 1000 mm^2</code>,
      <code>d := 450 mm</code> y luego <code>Mn := As*fy*d = kN*m</code>. Doble clic edita
      una región, arrastra para moverla, Supr la borra. La hoja se guarda automáticamente
      en el navegador.
    </p>
  </main>
  <Footer />
</BaseLayout>
