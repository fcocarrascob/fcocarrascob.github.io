---
import PageLayout from '../../../layouts/PageLayout.astro';
import PostCard from '../../../components/ui/PostCard.astro';
import { getHormigonPostsBySubsection, SUBSECTIONS } from '../../../lib/hormigon';

const sub = SUBSECTIONS['ejemplos'];
const posts = await getHormigonPostsBySubsection('ejemplos');

const capNum = (chapter?: string) => parseInt(chapter?.match(/\d+/)?.[0] ?? '999');
const sorted = [...posts].sort((a, b) => capNum(a.data.chapter) - capNum(b.data.chapter));
---
<PageLayout title={sub.label} description={sub.description}>
  <div class="mb-10">
    <a href="/hormigon" class="text-sm text-muted hover:text-ink transition-colors">
      &larr; Hormigón
    </a>
    <div class="mt-4">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-2">
        {sub.norm}
      </p>
      <h1 class="text-2xl font-semibold text-ink mb-3">{sub.label}</h1>
      <p class="text-muted leading-relaxed">{sub.description}</p>
    </div>
  </div>

  {sorted.length > 0 ? (
    <section>
      {sorted.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/hormigon/${post.id}`}
          tags={post.data.tags}
          section={post.data.chapter}
        />
      ))}
    </section>
  ) : (
    <p class="text-muted">No hay ejemplos publicados todavía.</p>
  )}
</PageLayout>
