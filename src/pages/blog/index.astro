---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/ui/PostCard.astro';
import { getPostGroups } from '../../lib/posts';

const groups = await getPostGroups();
const total = groups.reduce((n, g) => n + g.posts.length, 0);
---
<PageLayout title="Notas" description="Archivo de todas las notas de ingeniería estructural">
  <div class="mb-10">
    <h1 class="text-2xl font-semibold text-ink mb-2">Notas</h1>
    <p class="text-muted text-sm">{total} entrada{total !== 1 ? 's' : ''}</p>
  </div>

  {total === 0 ? (
    <p class="text-muted">No hay notas publicadas todavía.</p>
  ) : (
    groups.map((group) => (
      <section class="mb-12 last:mb-0">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted mb-1">
          {group.kind === 'series' ? `Serie · ${group.name}` : group.name}
        </h2>
        {group.posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            href={`/blog/${post.id}`}
            tags={post.data.tags}
            norm={post.data.norm}
            section={post.data.section}
            seriesPart={group.kind === 'series' ? post.data.seriesPart : undefined}
          />
        ))}
      </section>
    ))
  )}
</PageLayout>
