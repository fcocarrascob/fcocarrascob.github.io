---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { SUBSECTIONS, isSinglePost } from '../../lib/apuntes';
import type { SubsectionKey } from '../../lib/apuntes';

export async function getStaticPaths() {
  const posts = await getCollection('apuntes', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const subKey = post.data.subsection as SubsectionKey;
const sub = SUBSECTIONS[subKey];

// Nota única (norma corta): el breadcrumb vuelve a la sección Apuntes, porque no
// existe una página-galería intermedia. Multi-nota: vuelve a su galería.
const breadcrumb = isSinglePost(subKey)
  ? { href: '/apuntes', label: 'Apuntes' }
  : { href: `/apuntes/${subKey}`, label: sub?.label ?? subKey };
---
<BlogPost
  frontmatter={{
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    tags: post.data.tags,
    norm: sub?.author,
    section: post.data.chapter ?? sub?.label,
  }}
  breadcrumb={breadcrumb}
>
  <Content />
</BlogPost>
