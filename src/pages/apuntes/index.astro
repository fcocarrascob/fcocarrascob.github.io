---
import PageLayout from '../../layouts/PageLayout.astro';
import { getAllApuntes, SUBSECTIONS } from '../../lib/apuntes';

const posts = await getAllApuntes();

const subsectionCounts = Object.fromEntries(
  Object.keys(SUBSECTIONS).map((key) => [
    key,
    posts.filter((p) => p.data.subsection === key).length,
  ])
);
---
<PageLayout title="Apuntes" description="Apuntes didácticos de libros: teoría explicada paso a paso con esquemas">
  <div class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-2">Sección</p>
    <h1 class="text-2xl font-semibold text-ink mb-3">Apuntes</h1>
    <p class="text-muted leading-relaxed">
      Apuntes de libros: cada nota destila un capítulo en una clase visual — la intuición
      primero, luego la definición formal, un ejemplo y esquemas dibujados a mano.
    </p>
  </div>

  <section class="mb-12">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">Libros</h2>
    <ul class="divide-y divide-border border-y border-border">
      {Object.entries(SUBSECTIONS).map(([slug, sub]) => (
        <li>
          <a
            href={`/apuntes/${slug}`}
            class="flex items-center justify-between py-4 group"
          >
            <div>
              <p class="font-medium text-ink group-hover:text-accent transition-colors">
                {sub.label}
              </p>
              <p class="text-sm text-muted mt-0.5">{sub.author}</p>
              <p class="text-sm text-muted mt-1">{sub.description}</p>
            </div>
            <span class="shrink-0 ml-6 text-sm text-muted">
              {subsectionCounts[slug] ?? 0} nota{subsectionCounts[slug] !== 1 ? 's' : ''}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</PageLayout>
