---
import PageLayout from '../../layouts/PageLayout.astro';
import { getAllAceroPosts, SUBSECTIONS } from '../../lib/acero';

const posts = await getAllAceroPosts();

const subsectionCounts = Object.fromEntries(
  Object.keys(SUBSECTIONS).map((key) => [
    key,
    posts.filter((p) => p.data.subsection === key).length,
  ])
);
---
<PageLayout title="Acero" description="Notas de diseño de estructuras de acero">
  <div class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-2">Sección</p>
    <h1 class="text-2xl font-semibold text-ink mb-3">Acero</h1>
    <p class="text-muted leading-relaxed">
      Notas de diseño de estructuras de acero: normas, procesos de cálculo, tablas de
      referencia y ecuaciones fundamentales.
    </p>
  </div>

  <section class="mb-12">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">Sub-secciones</h2>
    <ul class="divide-y divide-border border-y border-border">
      {Object.entries(SUBSECTIONS).map(([slug, sub]) => (
        <li>
          <a
            href={`/acero/${slug}`}
            class="flex items-center justify-between py-4 group"
          >
            <div>
              <p class="font-medium text-ink group-hover:text-accent transition-colors">
                {sub.label}
              </p>
              <p class="text-sm text-muted mt-0.5">{sub.description}</p>
            </div>
            <span class="shrink-0 ml-6 text-sm text-muted">
              {subsectionCounts[slug] ?? 0} nota{subsectionCounts[slug] !== 1 ? 's' : ''}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</PageLayout>
