---
import PageLayout from '../layouts/PageLayout.astro';

const projects = [
  {
    title: 'Revisión Estructural Truck Shop 30ton',
    description: '<strong>Cliente:</strong> Stracon Group<br/><strong>Ubicación:</strong> Antamina, Áncash, Perú<br/><strong>Descripción:</strong> Revisión estructural de Truck Shop de 2 bahías para puente grúa de 30 ton. Revisión sísmica según normativa peruana; verificación de resistencias y deformaciones verticales/laterales. <br/><strong>Normas:</strong> RNE · ASCE 7 · ACI 318 · AISC 341 · AISC 360',
    image: '/portfolio/macadam.png',
    alt: 'Revisión Estructural Truck Shop 30ton',
    imageLeft: false,
  },
  {
    title: 'Losa de Aproximación Chancador',
    description: '<strong>Cliente:</strong> AMSA <br/><strong>Ubicación:</strong>Nueva Centinela, Sierra Gorda <br/><strong>Descripción:</strong> Análisis y diseño de Losas de Aproximación hacia Chancador Primario; Camión de Carga KOMATSU 980E-5, análisis de resistencia y estabilidad.<br/><strong>Normas:</strong> ACI 318 · NCh170 · NCh430 · NCh3171',
    image: '/portfolio/losa_aprox.png',
    alt: 'Título del proyecto',
    imageLeft: true,
  },
];
---
<PageLayout title="Acerca de" description="Sobre struct/pad">
  <div class="prose prose-slate max-w-none">
    <h1>Acerca de</h1>
    <p>
      <strong>struct/pad</strong> es un espacio personal para documentar apuntes,
      resúmenes y notas de ingeniería estructural. El contenido abarca normas de
      diseño, procesos de cálculo, ecuaciones y referencias técnicas.
    </p>
    <p>
      El objetivo es consolidar conocimiento de forma ordenada y accesible, con
      énfasis en la claridad del desarrollo técnico.
    </p>
  </div>

  <div class="mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-6">Portafolio</h2>
    <div class="divide-y divide-[var(--color-border)]">
      {projects.map((p) => (
        <div class={`flex gap-6 py-6 items-start ${p.imageLeft ? 'flex-row-reverse' : ''}`}>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-[var(--color-ink)] leading-snug">{p.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-muted)] leading-relaxed" set:html={p.description} />
          </div>
          <div class="w-1/2 shrink-0">
            <img
              src={p.image}
              alt={p.alt}
              class="w-full h-auto rounded"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
