---
import PageLayout from '../../layouts/PageLayout.astro';

const subsections = [
  {
    slug: 'portafolio',
    label: 'Portafolio',
    description: 'Proyectos de ingeniería estructural realizados.',
  },
];
---
<PageLayout title="Acerca de" description="Sobre struct/pad">
  <div class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-2">Sección</p>
    <h1 class="text-2xl font-semibold text-ink mb-3">Acerca de</h1>
    <p class="text-muted leading-relaxed">
      <strong>struct/pad</strong> es un espacio personal para documentar apuntes,
      resúmenes y notas de ingeniería estructural. El contenido abarca normas de
      diseño, procesos de cálculo, ecuaciones y referencias técnicas.
    </p>
    <p class="text-muted leading-relaxed mt-3">
      El objetivo es consolidar conocimiento de forma ordenada y accesible, con
      énfasis en la claridad del desarrollo técnico.
    </p>
  </div>

  <section class="mb-12">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">Sub-secciones</h2>
    <ul class="divide-y divide-border border-y border-border">
      {subsections.map((sub) => (
        <li>
          <a
            href={`/about/${sub.slug}`}
            class="flex items-center justify-between py-4 group"
          >
            <div>
              <p class="font-medium text-ink group-hover:text-accent transition-colors">
                {sub.label}
              </p>
              <p class="text-sm text-muted mt-0.5">{sub.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</PageLayout>
